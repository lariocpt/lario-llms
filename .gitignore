# Ignore Bifrost data (API keys, logs, etc.)
bifrost/
!bifrost/config.yaml

# Ignore generated images and temporary script outputs
ml_env/scripts/*.png
ml_env/scripts/*.jpg
ml_env/scripts/*.wav

# Ignore Python cache
__pycache__/
*.pyc

# ChromaDB vector data
chroma-data/

# Dev container build artifacts
dev-containers/*.tar.gz
dev-containers/yazi
dev-containers/gram
dev-containers/.opencode/
