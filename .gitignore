# Ignore ALL Bifrost runtime data including config.db. config.db is a live-mutating SQLite
# DB — tracking it caused a branch-switch to revert it mid-WAL and crash Bifrost with
# "database disk image is malformed". The provider config it holds (ollama -> http://ollama:11434,
# network_config.allow_private_network=true) is documented in fedora-llms/04-bifrost-routing-security.md.
bifrost/

# Ignore generated images and temporary script outputs
ml_env/scripts/*.png
ml_env/scripts/*.jpg
ml_env/scripts/*.wav

# Ignore Python cache
__pycache__/
*.pyc

# ChromaDB vector data
chroma-data/

# Dev container build artifacts
dev-containers/*.tar.gz
dev-containers/yazi
dev-containers/gram
dev-containers/.opencode/
dev-containers/splashboard
dev-containers/.splashboard/secrets.toml
dev-containers/.harlequin.toml




# Python virtualenvs
.venv/
**/.venv/
