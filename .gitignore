# Ignore Bifrost runtime data (logs.db, sessions, etc.). Keep config.db — the provider/model
# routing config (verified secret-free: ollama-only, no cloud keys). Source of truth.
# NOTE: bifrost writes config.db live, so it shows as modified after running; re-commit intentionally.
bifrost/*
!bifrost/config.db

# Ignore generated images and temporary script outputs
ml_env/scripts/*.png
ml_env/scripts/*.jpg
ml_env/scripts/*.wav

# Ignore Python cache
__pycache__/
*.pyc

# ChromaDB vector data
chroma-data/

# Dev container build artifacts
dev-containers/*.tar.gz
dev-containers/yazi
dev-containers/gram
dev-containers/.opencode/
dev-containers/splashboard
dev-containers/.splashboard/secrets.toml
dev-containers/.harlequin.toml



