{
  "provider": "opencode",
  "model": "openai/qwen-routing",
  "effort": "medium",
  "skills": "all",
  "groupName": "__GROUP_NAME__",
  "assistantName": "__ASSISTANT_NAME__",
  "agentGroupId": "",
  "mcpServers": {},
  "packages": {
    "apt": ["git", "openssh-client"],
    "npm": []
  },
  "additionalMounts": [
    { "hostPath": "__AGENT_DIR__/workspace", "containerPath": "/workspace", "readonly": false },
    { "hostPath": "__HOME__/.ssh", "containerPath": "/root/.ssh", "readonly": true }
  ]
}
