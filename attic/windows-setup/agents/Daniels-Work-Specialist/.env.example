# Per-agent secrets for a Hermes agent. Copy to `.env` (gitignored) and fill in.

# ─── Discord bot (one bot per agent) ─────────────────────────────────────────
# Create an app at https://discord.com/developers/applications, add a Bot,
# enable Message Content + Server Members + Presence intents, invite it to your
# server, then paste the values here. See docs/DEPLOY.md.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Who may talk to the bot. WITHOUT one of these the gateway connects but DENIES
# every user (bot looks dead). Allow anyone (simplest for a personal/website bot):
DISCORD_ALLOW_ALL_USERS=true
# …or restrict to specific Discord user id(s) instead:
# DISCORD_ALLOWED_USERS=<your_discord_user_id>,<another>

# ─── LLM gateway (Bifrost is keyless; placeholder satisfies the SDK header) ───
OPENAI_API_KEY=local-bifrost

TZ=Africa/Johannesburg
